<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base frosted glass fill: gradient top(lighter)-to-bottom(darker) -->
    <item>
        <shape>
            <gradient
                android:angle="270"
                android:startColor="@color/glass_fill_top"
                android:endColor="@color/glass_fill_bottom"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Diagonal light catch, like light hitting glass from top-left -->
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:startColor="@color/glass_highlight"
                android:centerColor="#00FFFFFF"
                android:endColor="#00FFFFFF"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Border -->
    <item>
        <shape>
            <stroke
                android:width="1dp"
                android:color="@color/glass_stroke" />
            <corners android:radius="20dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
